# CCR Client-Side Confidential Relay — Environment Variables Template
# Copy to ~/.claude/.env or source before running CCR
# Generate RELAY_KEY with: openssl rand -hex 32

# Relay URL (your Vercel deployment + /api/relay)
# After deploying: vercel deploy --prod → copy URL
RELAY_URL=<your-vercel-deployment-url>/api/relay

# Must match RELAY_KEY in Vercel dashboard
RELAY_RELAY_KEY=<generate-with-openssl-rand-hex-32>
