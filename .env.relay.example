# Confidential Relay — Server-Side Environment Variables Template
# Copy to Vercel dashboard → Settings → Environment Variables
# Generate RELAY_KEY with: openssl rand -hex 32

# AES-256-GCM key — 64 hex characters (32 bytes)
RELAY_KEY=<generate-with-openssl-rand-hex-32>

# Provider API Keys (only add keys for providers you use)
ANTHROPIC_API_KEY=sk-ant-...
MINIMAX_API_KEY=...
CODEX_API_KEY=...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=...

# AWS credentials for Bedrock (if using)
BEDROCK_AWS_ACCESS_KEY_ID=...
BEDROCK_AWS_SECRET_ACCESS_KEY=...
BEDROCK_AWS_REGION=us-east-1
