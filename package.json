{
  "name": "microservice-suite",
  "module": "ESNext",
  "target": "bun",
  "type": "module",
  "scripts": {
    "dev": "echo 'Run individual services with: bun --watch services/*/server.ts'",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:services": "find services -name '*.test.ts' -exec bun test {} \\;",
    "start:auth": "bun --watch services/auth/server.ts",
    "start:users": "bun --watch services/users/server.ts"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}