{
  "name": "microservice-suite",
  "module": "ESNext",
  "target": "bun",
  "type": "module",
  "scripts": {
    "dev": "echo 'See README.md for service startup commands (uses services/*/index.ts)'",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:services": "bun services/run-tests.ts",
    "test:all": "bun test services/",
    "start:auth": "bun --watch services/auth/index.ts",
    "start:users": "bun --watch services/users/index.ts",
    "start:products": "bun --watch services/products/index.ts",
    "start:orders": "bun --watch services/orders/index.ts",
    "start:payments": "bun --watch services/payments/index.ts",
    "start:notifications": "bun --watch services/notifications/index.ts",
    "start:analytics": "bun --watch services/analytics/index.ts",
    "start:search": "bun --watch services/search/index.ts"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}